# Timezone
TZ=Asia/Ho_Chi_Minh

# Database (postgres-js with SSL CA)
DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/DB?sslmode=require
PGSSLROOTCERT=../certs/ca.crt

# Optional cache / queue
REDIS_URL=

# BetterAuth
# openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-with-32+-char-random
BETTER_AUTH_URL=http://localhost:3000

# Azure AD / Microsoft OIDC (MVP-3)
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=

# Test-only login backdoor — TEST ONLY. MUST stay false / empty in production.
# When both are set, POST /api/auth/test-login mints a real session without
# Microsoft OAuth (requires a matching `x-test-login: <token>` header). Used by
# the vitest/Playwright runners; leaving these unset keeps the endpoint a 404.
TEST_LOGIN_ENABLED=false
TEST_LOGIN_TOKEN=

# Persistent data paths
# DATA_DIR — base dir for all persistent data. Default: production /data, dev <project_root>.
# WORKSPACE_ROOT — user project workspaces. Default: ${DATA_DIR}/workspace.
# CLAUDE_CONFIG_DIR — ROOT for per-user agent state (config + JSONL transcripts).
#   Default: ${DATA_DIR}/agent-state. Per-user subdirs (<root>/<userSlug>) are
#   appended automatically; the var keeps the SDK-standard name.
# All three resolve to absolute paths; relative values resolve against the process cwd.
# CLAUDE_CONFIG_DIR is a sibling of WORKSPACE_ROOT, never inside it.
DATA_DIR=
WORKSPACE_ROOT=
CLAUDE_CONFIG_DIR=
MAX_UPLOAD_BYTES=104857600

# Server
PORT=3000
LOG_LEVEL=info
NODE_ENV=development
