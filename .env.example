# Database (postgres-js with SSL CA)
DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/DB?sslmode=require
PGSSLROOTCERT=../certs/ca.crt

# Optional cache / queue
REDIS_URL=

# BetterAuth (configured at MVP-3)
BETTER_AUTH_SECRET=replace-me-with-32+-char-random
BETTER_AUTH_URL=http://localhost:3000

# Azure AD / Microsoft OIDC (MVP-3)
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

# File / workspace
# Optional. If empty: dev/test default to <project_root>/workspace; production requires an explicit value.
# Relative paths are resolved against the process cwd.
WORKSPACE_ROOT=
MAX_UPLOAD_BYTES=104857600

# Server
PORT=3000
LOG_LEVEL=info
NODE_ENV=development

# Kimi CLI / SDK config
# KIMI_SHARE_DIR=/data/kimi
# KIMI_CLI_NO_AUTO_UPDATE=1

# Optional seed values for first-boot kimi_config (consumed once, then stored in DB)
# KIMI_SEED_PROVIDER_TYPE=kimi
# KIMI_SEED_PROVIDER_BASE_URL=https://api.kimi.com/coding/v1
# KIMI_SEED_PROVIDER_API_KEY=
# KIMI_SEED_DEFAULT_MODEL=kimi-code/kimi-for-coding
# KIMI_SEED_MODEL_PROVIDER=managed:kimi-code
# KIMI_SEED_MODEL_NAME=kimi-for-coding
# KIMI_SEED_MODEL_MAX_CONTEXT_SIZE=262144
# KIMI_SEED_MODEL_CAPABILITIES=image_in,video_in,thinking
# KIMI_SEED_MODEL_DISPLAY_NAME=Kimi-k2.6
