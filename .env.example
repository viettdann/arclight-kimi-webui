# Database (postgres-js with SSL CA)
DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/DB?sslmode=require
PGSSLROOTCERT=../certs/ca.crt

# Optional cache / queue
REDIS_URL=

# BetterAuth (configured at MVP-3)
BETTER_AUTH_SECRET=replace-me-with-32+-char-random
BETTER_AUTH_URL=http://localhost:3000

# Azure AD / Microsoft OIDC (MVP-3)
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

# File / workspace
# Optional. If empty: dev/test default to <project_root>/workspace; production requires an explicit value.
# Relative paths are resolved against the process cwd.
WORKSPACE_ROOT=
MAX_UPLOAD_BYTES=104857600

# Server
PORT=3000
LOG_LEVEL=info
NODE_ENV=development

# Kimi CLI / SDK config
# Isolates webui from your host ~/.kimi (config.toml, oauth, sessions, logs).
# Default (unset): dev → <project_root>/.kimi (sibling of workspace/), prod → /app/.kimi.
# Relative values resolve against <project_root>; absolute values are used as-is.
# KIMI_SHARE_DIR=
# KIMI_CLI_NO_AUTO_UPDATE=1

# Controls whether bootstrap renders .kimi/config.toml from the DB row.
#   if-missing (default) — write only when the file does not exist
#   always               — overwrite every boot (legacy behavior)
#   never                — never write at boot; use PATCH /api/config or
#                          POST /api/config/sync-toml to materialize the file
# KIMI_CONFIG_WRITE_TOML=if-missing

# Optional baseline values for kimi_config. Used only when the DB row is
# absent (DB > env > DEFAULT_KIMI_CONFIG per field). Once PATCH /api/config
# writes the row, these env vars are ignored.
# KIMI_PROVIDER_TYPE=kimi
# KIMI_BASE_URL=https://api.kimi.com/coding/v1
# KIMI_API_KEY=
# KIMI_DEFAULT_MODEL=kimi-code/kimi-for-coding
# KIMI_MODEL_PROVIDER=managed:kimi-code
# KIMI_MODEL_NAME=kimi-for-coding
# KIMI_MODEL_MAX_CONTEXT_SIZE=262144
# KIMI_MODEL_CAPABILITIES=image_in,video_in,thinking
# KIMI_MODEL_DISPLAY_NAME=Kimi-k2.6
