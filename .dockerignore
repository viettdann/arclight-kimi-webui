# VCS
.git
.gitignore

# Deps & caches
**/node_modules
**/.turbo
**/.vite
**/.cache
**/*.tsbuildinfo
.code-review-graph

# Build outputs
**/dist
**/build
coverage

# Tests & dev-only scripts — not needed by `bun build --compile` or migrator
**/test
server/scripts
playwright-report
test-results

# Secrets & runtime state — never ship in the build context
.env
.env.*
certs
.kimi
workspace
agent-state
.antigravitycli
.runtime
.claude

# Docs are the user's personal works
docs

reference

# Editor / OS junk
.vscode
.idea
**/.DS_Store
**/*.sw?
**/*.log
Thumbs.db

# Markdown / meta files
**/*.md
compose.yaml
compose.local.yaml
compose.dev.yaml
compose.infra.yaml
Dockerfile
.dockerignore
docker
claude-config