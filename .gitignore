node_modules/
dist/
.turbo/
.vite/
.cache/
*.tsbuildinfo
coverage/

# Env
.env
.env.*.local
# `.env.*.local` only matches a middle segment (e.g. .env.foo.local); these two
# need explicit entries or they get committed. `.env.example` stays tracked.
.env.local
.env.development

# OS
.DS_Store

# Logs
*.log
logs/

# Editor / tooling
.vscode/
.idea/
.antigravitycli
.claude/*.lock
.code-review-graph/

# Bun — commit `bun.lock` (text) for reproducible installs; ignore legacy binary lockfile.
bun.lockb

# Certs — whitelist only the CA bundle, ignore everything else (private keys, etc.)
certs/*
!certs/ca.crt

# Runtime state & agent share dirs — see KIMI_SHARE_DIR (.kimi: config.toml, oauth, sessions, logs)
.kimi/
.runtime/
claude-config/
agent-state/
workspace/*
!workspace/.gitkeep
data/
data/agent-state/
data/workspace/*

# Build / test artifacts
reference/
playwright-report/
test-results/

# Local overrides
compose.local.yaml
