{
  "name": "server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun --watch --env-file=../.env src/index.ts",
    "start": "bun --env-file=../.env src/index.ts",
    "build": "bun build --target=bun --outdir dist src/index.ts",
    "check": "tsc --noEmit",
    "test": "bun test",
    "db:generate": "bun --env-file=../.env scripts/db-generate.ts",
    "db:migrate": "bun --env-file=../.env x drizzle-kit migrate",
    "db:push": "bun --env-file=../.env x drizzle-kit push",
    "db:studio": "bun --env-file=../.env x drizzle-kit studio"
  },
  "dependencies": {
    "@moonshot-ai/kimi-agent-sdk": "0.1.8",
    "better-auth": "1.6.9",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.16",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "postgres": "3.4.9",
    "shared": "workspace:*",
    "zod": "4.4.1"
  },
  "devDependencies": {
    "@types/bun": "1.3.13",
    "drizzle-kit": "0.31.10",
    "typescript": "^5.9.3"
  }
}
